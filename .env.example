# Shared
JWT_SECRET=jwt_secret_here
RABBITMQ_URL=amqp://localhost:5672

# Database URLs (one per service, Neon Postgres)
MENU_DATABASE_URL=postgresql://user:pass@host/menu_db
ORDERS_DATABASE_URL=postgresql://user:pass@host/orders_db
PAYMENTS_DATABASE_URL=postgresql://user:pass@host/payments_db
USERS_DATABASE_URL=postgresql://user:pass@host/users_db

# API Gateway service URLs (defaults work for local dev)
MENU_SERVICE_URL=http://localhost:3000
ORDER_SERVICE_URL=http://localhost:3001
PAYMENT_SERVICE_URL=http://localhost:3002
USER_SERVICE_URL=http://localhost:3004

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (notification-service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASS=app_password
